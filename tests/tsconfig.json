{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
		"paths": {
			"$src/*": ["./src/*"],
			"$package/*": ["../package/src/*"],
			"$package": ["../package/src/index.ts"],
		}
  },
  "include": ["src"]
}